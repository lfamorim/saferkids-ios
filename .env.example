# Public hostname or IP of this server (the one your iPhone will reach).
# Examples: vpn.example.com   or   203.0.113.10
WG_HOST=change-me.example.com

# Bcrypt hash for the wg-easy web UI password.
# Generate with:
#   docker run --rm ghcr.io/wg-easy/wg-easy:14 wgpw 'YourStrongPassword'
# Then paste the resulting hash below (keep the single quotes around the value
# if it contains $ characters, or escape every $ as $$ inside docker-compose).
WG_PASSWORD_HASH=$$2a$$12$$REPLACE_WITH_BCRYPT_HASH

# Friendly AirPlay name shown on the iPhone "Screen Mirroring" picker.
UXPLAY_NAME=saferkids

# MP4 segment length (seconds). Each AirPlay session is also split into
# files of this length. 600 = 10 minutes per file.
SEGMENT_SECONDS=600

# ── Monitor / detecção de evasão ─────────────────────────────────────────────
# Token compartilhado entre o servidor e o Atalho iOS de heartbeat. Gere
# qualquer string aleatória forte: `openssl rand -hex 24`.
HEARTBEAT_TOKEN=

# Alertas via Telegram (mais simples). Crie um bot com @BotFather, pegue o
# token e descubra seu chat_id (https://t.me/userinfobot).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Alternativa/adicional: webhook genérico (Discord, Slack, n8n…). JSON POST.
ALERT_WEBHOOK_URL=

# Tunables (segundos). Defaults razoáveis para iPhone com keepalive=25s.
DARK_AFTER_SECONDS=120
OFFLINE_AFTER_SECONDS=1800
# IDLE = "VPN ligada mas AirPlay desligado". Alertar após N segundos nesse
# estado (criança usando o iPhone sem mirroring ativo).
IDLE_GRACE_SECONDS=300
# Janela horária local em que alertas são enviados (HH:MM-HH:MM, 24h).
# Fora dela o monitor fica em "modo silencioso" pra não alertar de madrugada.
USAGE_WINDOW=07:00-22:00
TZ=America/Sao_Paulo
